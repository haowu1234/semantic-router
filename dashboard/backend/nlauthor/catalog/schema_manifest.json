{
  "version": "v1alpha1",
  "signals": [
    {
      "typeName": "keyword",
      "description": "Match specific keywords or patterns in text.",
      "fields": [
        {
          "key": "operator",
          "label": "Operator",
          "type": "select",
          "options": [
            "any",
            "all",
            "OR",
            "AND"
          ],
          "required": true
        },
        {
          "key": "keywords",
          "label": "Keywords",
          "type": "string[]",
          "required": true,
          "placeholder": "Add keyword..."
        },
        {
          "key": "method",
          "label": "Method",
          "type": "select",
          "options": [
            "regex",
            "bm25",
            "ngram"
          ]
        },
        {
          "key": "case_sensitive",
          "label": "Case Sensitive",
          "type": "boolean"
        },
        {
          "key": "fuzzy_match",
          "label": "Fuzzy Match",
          "type": "boolean"
        },
        {
          "key": "fuzzy_threshold",
          "label": "Fuzzy Threshold",
          "type": "number",
          "placeholder": "2"
        },
        {
          "key": "bm25_threshold",
          "label": "BM25 Threshold",
          "type": "number"
        },
        {
          "key": "ngram_threshold",
          "label": "N-gram Threshold",
          "type": "number"
        },
        {
          "key": "ngram_arity",
          "label": "N-gram Arity",
          "type": "number"
        }
      ]
    },
    {
      "typeName": "embedding",
      "description": "Measure semantic similarity against candidate phrases.",
      "fields": [
        {
          "key": "threshold",
          "label": "Threshold",
          "type": "number",
          "required": true,
          "placeholder": "0.75"
        },
        {
          "key": "candidates",
          "label": "Candidates",
          "type": "string[]",
          "required": true,
          "placeholder": "Add candidate..."
        },
        {
          "key": "aggregation_method",
          "label": "Aggregation",
          "type": "select",
          "options": [
            "mean",
            "max",
            "any"
          ]
        }
      ]
    },
    {
      "typeName": "domain",
      "description": "Classify requests into topic domains.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string",
          "required": true
        },
        {
          "key": "mmlu_categories",
          "label": "MMLU Categories",
          "type": "string[]",
          "placeholder": "Add category..."
        },
        {
          "key": "model_scores",
          "label": "Model Scores",
          "type": "json"
        }
      ]
    },
    {
      "typeName": "fact_check",
      "description": "Detect fact-checking or verification intent.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "typeName": "user_feedback",
      "description": "Detect user feedback or preference signals.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "typeName": "preference",
      "description": "Model user preferences as a routing signal.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string",
          "required": true
        }
      ]
    },
    {
      "typeName": "language",
      "description": "Detect request language.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "context",
      "description": "Bucket requests by context length or token count.",
      "fields": [
        {
          "key": "min_tokens",
          "label": "Min Tokens",
          "type": "string",
          "required": true,
          "placeholder": "4K"
        },
        {
          "key": "max_tokens",
          "label": "Max Tokens",
          "type": "string",
          "required": true,
          "placeholder": "32K"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "complexity",
      "description": "Estimate task complexity to drive routing.",
      "fields": [
        {
          "key": "threshold",
          "label": "Threshold",
          "type": "number",
          "required": true,
          "placeholder": "0.1"
        },
        {
          "key": "hard",
          "label": "Hard Examples",
          "type": "json",
          "description": "e.g. { candidates: [\"...\"] }"
        },
        {
          "key": "easy",
          "label": "Easy Examples",
          "type": "json",
          "description": "e.g. { candidates: [\"...\"] }"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        },
        {
          "key": "composer",
          "label": "Composer",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "modality",
      "description": "Detect content modality such as text or image.",
      "fields": [
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "authz",
      "description": "Evaluate authorization or entitlement state.",
      "fields": [
        {
          "key": "subjects",
          "label": "Subjects",
          "type": "json",
          "required": true,
          "description": "[{ kind: \"Group\", name: \"...\" }]"
        },
        {
          "key": "role",
          "label": "Role",
          "type": "string",
          "required": true,
          "placeholder": "premium_tier"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "jailbreak",
      "description": "Detect jailbreak or prompt-injection attempts.",
      "fields": [
        {
          "key": "method",
          "label": "Method",
          "type": "select",
          "options": [
            "classifier",
            "contrastive"
          ],
          "description": "Detection algorithm"
        },
        {
          "key": "threshold",
          "label": "Threshold",
          "type": "number",
          "required": true,
          "placeholder": "0.9",
          "description": "Minimum score to trigger (0.0-1.0)"
        },
        {
          "key": "include_history",
          "label": "Include History",
          "type": "boolean",
          "description": "Include conversation history in detection"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        },
        {
          "key": "jailbreak_patterns",
          "label": "Jailbreak Patterns",
          "type": "string[]",
          "placeholder": "Add jailbreak example...",
          "description": "Contrastive mode: example jailbreak prompts"
        },
        {
          "key": "benign_patterns",
          "label": "Benign Patterns",
          "type": "string[]",
          "placeholder": "Add benign example...",
          "description": "Contrastive mode: example benign prompts"
        }
      ]
    },
    {
      "typeName": "pii",
      "description": "Detect personally identifiable information.",
      "fields": [
        {
          "key": "threshold",
          "label": "Threshold",
          "type": "number",
          "required": true,
          "placeholder": "0.8",
          "description": "Minimum confidence for PII detection (0.0-1.0)"
        },
        {
          "key": "pii_types_allowed",
          "label": "PII Types Allowed",
          "type": "string[]",
          "placeholder": "e.g. EMAIL_ADDRESS",
          "description": "PII types to allow through"
        },
        {
          "key": "include_history",
          "label": "Include History",
          "type": "boolean",
          "description": "Include conversation history in detection"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    }
  ],
  "plugins": [
    {
      "typeName": "semantic_cache",
      "description": "Cache semantically similar queries to reduce latency and cost.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "similarity_threshold",
          "label": "Similarity Threshold",
          "type": "number",
          "placeholder": "0.95",
          "description": "Minimum similarity for cache hit (0-1)"
        }
      ]
    },
    {
      "typeName": "memory",
      "description": "Persist and retrieve conversational memory.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "retrieval_limit",
          "label": "Retrieval Limit",
          "type": "number",
          "placeholder": "5"
        },
        {
          "key": "similarity_threshold",
          "label": "Similarity Threshold",
          "type": "number",
          "placeholder": "0.7"
        },
        {
          "key": "auto_store",
          "label": "Auto Store",
          "type": "boolean"
        }
      ]
    },
    {
      "typeName": "system_prompt",
      "description": "Inject or replace system prompts.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "system_prompt",
          "label": "System Prompt",
          "type": "string",
          "required": true,
          "placeholder": "You are a helpful assistant..."
        },
        {
          "key": "mode",
          "label": "Mode",
          "type": "select",
          "options": [
            "",
            "replace",
            "insert"
          ],
          "description": "Replace or insert before an existing prompt"
        }
      ]
    },
    {
      "typeName": "header_mutation",
      "description": "Add, update, or remove headers.",
      "fields": [
        {
          "key": "add",
          "label": "Add Headers",
          "type": "json",
          "description": "[{ \"name\": \"X-Custom\", \"value\": \"...\" }]"
        },
        {
          "key": "update",
          "label": "Update Headers",
          "type": "json",
          "description": "[{ \"name\": \"X-Custom\", \"value\": \"...\" }]"
        },
        {
          "key": "delete",
          "label": "Delete Headers",
          "type": "string[]",
          "placeholder": "Header name to delete"
        }
      ]
    },
    {
      "typeName": "hallucination",
      "description": "Detect hallucinated content and attach mitigation.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "use_nli",
          "label": "Use NLI",
          "type": "boolean"
        },
        {
          "key": "hallucination_action",
          "label": "Action",
          "type": "select",
          "options": [
            "",
            "header",
            "body",
            "none"
          ]
        }
      ]
    },
    {
      "typeName": "router_replay",
      "description": "Capture request and response pairs for replay.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "max_records",
          "label": "Max Records",
          "type": "number",
          "placeholder": "10000"
        },
        {
          "key": "capture_request_body",
          "label": "Capture Request Body",
          "type": "boolean"
        },
        {
          "key": "capture_response_body",
          "label": "Capture Response Body",
          "type": "boolean"
        },
        {
          "key": "max_body_bytes",
          "label": "Max Body Bytes",
          "type": "number",
          "placeholder": "4096"
        }
      ]
    },
    {
      "typeName": "rag",
      "description": "Inject retrieved context from a backend.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "backend",
          "label": "Backend",
          "type": "string",
          "required": true,
          "placeholder": "my_vector_store"
        },
        {
          "key": "top_k",
          "label": "Top K",
          "type": "number",
          "placeholder": "5"
        },
        {
          "key": "similarity_threshold",
          "label": "Similarity Threshold",
          "type": "number",
          "placeholder": "0.7"
        },
        {
          "key": "injection_mode",
          "label": "Injection Mode",
          "type": "select",
          "options": [
            "",
            "system",
            "user",
            "context"
          ]
        },
        {
          "key": "on_failure",
          "label": "On Failure",
          "type": "select",
          "options": [
            "",
            "skip",
            "fail"
          ]
        },
        {
          "key": "backend_config",
          "label": "Backend Config",
          "type": "json"
        }
      ]
    },
    {
      "typeName": "image_gen",
      "description": "Route requests to image-generation backends.",
      "fields": [
        {
          "key": "enabled",
          "label": "Enabled",
          "type": "boolean"
        },
        {
          "key": "backend",
          "label": "Backend",
          "type": "string",
          "required": true,
          "placeholder": "my_image_backend"
        }
      ]
    },
    {
      "typeName": "fast_response",
      "description": "Return a static response without upstream model calls.",
      "fields": [
        {
          "key": "message",
          "label": "Message",
          "type": "string",
          "required": true,
          "placeholder": "I cannot help with that request."
        }
      ]
    }
  ],
  "algorithms": [
    {
      "typeName": "confidence",
      "description": "Escalate to stronger models when confidence is low.",
      "fields": [
        {
          "key": "confidence_method",
          "label": "Confidence Method",
          "type": "select",
          "options": [
            "avg_logprob",
            "margin",
            "hybrid",
            "self_verify"
          ]
        },
        {
          "key": "threshold",
          "label": "Threshold",
          "type": "number",
          "placeholder": "-1.0"
        },
        {
          "key": "on_error",
          "label": "On Error",
          "type": "select",
          "options": [
            "",
            "skip",
            "fail"
          ]
        },
        {
          "key": "escalation_order",
          "label": "Escalation Order",
          "type": "select",
          "options": [
            "",
            "size",
            "cost",
            "automix"
          ]
        },
        {
          "key": "cost_quality_tradeoff",
          "label": "Cost/Quality Tradeoff",
          "type": "number",
          "placeholder": "0.3"
        }
      ]
    },
    {
      "typeName": "ratings",
      "description": "Call multiple models concurrently for side-by-side outputs.",
      "fields": [
        {
          "key": "max_concurrent",
          "label": "Max Concurrent",
          "type": "number",
          "placeholder": "0"
        },
        {
          "key": "on_error",
          "label": "On Error",
          "type": "select",
          "options": [
            "",
            "skip",
            "fail"
          ]
        }
      ]
    },
    {
      "typeName": "remom",
      "description": "Use multi-round parallel reasoning and synthesis.",
      "fields": [
        {
          "key": "breadth_schedule",
          "label": "Breadth Schedule",
          "type": "number[]",
          "required": true,
          "placeholder": "e.g. 32"
        },
        {
          "key": "model_distribution",
          "label": "Model Distribution",
          "type": "select",
          "options": [
            "",
            "weighted",
            "equal",
            "first_only"
          ]
        },
        {
          "key": "temperature",
          "label": "Temperature",
          "type": "number",
          "placeholder": "1.0"
        },
        {
          "key": "include_reasoning",
          "label": "Include Reasoning",
          "type": "boolean"
        },
        {
          "key": "compaction_strategy",
          "label": "Compaction Strategy",
          "type": "select",
          "options": [
            "",
            "full",
            "last_n_tokens"
          ]
        },
        {
          "key": "compaction_tokens",
          "label": "Compaction Tokens",
          "type": "number",
          "placeholder": "1000"
        },
        {
          "key": "max_concurrent",
          "label": "Max Concurrent",
          "type": "number",
          "placeholder": "0"
        },
        {
          "key": "on_error",
          "label": "On Error",
          "type": "select",
          "options": [
            "",
            "skip",
            "fail"
          ]
        },
        {
          "key": "include_intermediate_responses",
          "label": "Include Intermediate",
          "type": "boolean"
        }
      ]
    },
    {
      "typeName": "static",
      "description": "Use static model ordering without additional parameters."
    },
    {
      "typeName": "elo",
      "description": "Select models using an Elo rating system.",
      "fields": [
        {
          "key": "initial_rating",
          "label": "Initial Rating",
          "type": "number",
          "placeholder": "1500"
        },
        {
          "key": "k_factor",
          "label": "K Factor",
          "type": "number",
          "placeholder": "32"
        },
        {
          "key": "category_weighted",
          "label": "Category Weighted",
          "type": "boolean"
        },
        {
          "key": "decay_factor",
          "label": "Decay Factor",
          "type": "number",
          "placeholder": "0"
        },
        {
          "key": "min_comparisons",
          "label": "Min Comparisons",
          "type": "number",
          "placeholder": "5"
        },
        {
          "key": "cost_scaling_factor",
          "label": "Cost Scaling",
          "type": "number",
          "placeholder": "0"
        },
        {
          "key": "storage_path",
          "label": "Storage Path",
          "type": "string",
          "placeholder": "/tmp/elo"
        }
      ]
    },
    {
      "typeName": "router_dc",
      "description": "Use contrastive query-model similarity for routing.",
      "fields": [
        {
          "key": "temperature",
          "label": "Temperature",
          "type": "number",
          "placeholder": "0.07"
        },
        {
          "key": "dimension_size",
          "label": "Dimension Size",
          "type": "number",
          "placeholder": "768"
        },
        {
          "key": "min_similarity",
          "label": "Min Similarity",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "use_query_contrastive",
          "label": "Query Contrastive",
          "type": "boolean"
        },
        {
          "key": "use_model_contrastive",
          "label": "Model Contrastive",
          "type": "boolean"
        }
      ]
    },
    {
      "typeName": "automix",
      "description": "Optimize quality and cost using an AutoMix-style cascade.",
      "fields": [
        {
          "key": "verification_threshold",
          "label": "Verification Threshold",
          "type": "number",
          "placeholder": "0.7"
        },
        {
          "key": "max_escalations",
          "label": "Max Escalations",
          "type": "number",
          "placeholder": "2"
        },
        {
          "key": "cost_aware_routing",
          "label": "Cost-Aware Routing",
          "type": "boolean"
        },
        {
          "key": "cost_quality_tradeoff",
          "label": "Cost/Quality Tradeoff",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "discount_factor",
          "label": "Discount Factor",
          "type": "number",
          "placeholder": "0.95"
        }
      ]
    },
    {
      "typeName": "hybrid",
      "description": "Blend multiple routing signals with tunable weights.",
      "fields": [
        {
          "key": "elo_weight",
          "label": "Elo Weight",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "router_dc_weight",
          "label": "RouterDC Weight",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "automix_weight",
          "label": "AutoMix Weight",
          "type": "number",
          "placeholder": "0.2"
        },
        {
          "key": "cost_weight",
          "label": "Cost Weight",
          "type": "number",
          "placeholder": "0.2"
        },
        {
          "key": "quality_gap_threshold",
          "label": "Quality Gap Threshold",
          "type": "number",
          "placeholder": "0.1"
        },
        {
          "key": "normalize_scores",
          "label": "Normalize Scores",
          "type": "boolean"
        }
      ]
    },
    {
      "typeName": "rl_driven",
      "description": "Use reinforcement-learning exploration and exploitation.",
      "fields": [
        {
          "key": "exploration_rate",
          "label": "Exploration Rate",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "use_thompson_sampling",
          "label": "Thompson Sampling",
          "type": "boolean"
        },
        {
          "key": "enable_personalization",
          "label": "Personalization",
          "type": "boolean"
        },
        {
          "key": "personalization_blend",
          "label": "Personalization Blend",
          "type": "number",
          "placeholder": "0.3"
        },
        {
          "key": "cost_awareness",
          "label": "Cost Awareness",
          "type": "boolean"
        }
      ]
    },
    {
      "typeName": "gmtrouter",
      "description": "Use graph-based personalization for routing.",
      "fields": [
        {
          "key": "enable_personalization",
          "label": "Personalization",
          "type": "boolean"
        },
        {
          "key": "history_sample_size",
          "label": "History Sample Size",
          "type": "number",
          "placeholder": "5"
        },
        {
          "key": "min_interactions_for_personalization",
          "label": "Min Interactions",
          "type": "number"
        },
        {
          "key": "max_interactions_per_user",
          "label": "Max Interactions/User",
          "type": "number",
          "placeholder": "100"
        },
        {
          "key": "model_path",
          "label": "Model Path",
          "type": "string",
          "placeholder": "/models/gmt"
        }
      ]
    },
    {
      "typeName": "latency_aware",
      "description": "Route with latency percentile constraints.",
      "fields": [
        {
          "key": "tpot_percentile",
          "label": "TPOT Percentile",
          "type": "number",
          "required": true,
          "placeholder": "20"
        },
        {
          "key": "ttft_percentile",
          "label": "TTFT Percentile",
          "type": "number",
          "required": true,
          "placeholder": "20"
        },
        {
          "key": "description",
          "label": "Description",
          "type": "string"
        }
      ]
    },
    {
      "typeName": "knn",
      "description": "Use nearest-neighbor model selection."
    },
    {
      "typeName": "kmeans",
      "description": "Use clustering-based model selection."
    },
    {
      "typeName": "svm",
      "description": "Use an SVM classifier for model selection."
    }
  ],
  "backends": [
    {
      "typeName": "vllm_endpoint",
      "description": "Declare one routable vLLM endpoint.",
      "fields": [
        {
          "key": "address",
          "label": "Address",
          "type": "string",
          "required": true,
          "placeholder": "127.0.0.1"
        },
        {
          "key": "port",
          "label": "Port",
          "type": "number",
          "required": true,
          "placeholder": "8000"
        },
        {
          "key": "weight",
          "label": "Weight",
          "type": "number",
          "placeholder": "1"
        },
        {
          "key": "type",
          "label": "Type",
